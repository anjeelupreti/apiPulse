DJANGO_ENV=dev
SECRET_KEY=change-me-in-prod

DB_NAME=pulsewatch
DB_USER=pulsewatch
DB_PASSWORD=pulsewatch
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0

# Gmail SMTP — use an app password (Google Account > Security > App
# passwords), not your real account password
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Google OAuth (console.cloud.google.com > APIs & Services > Credentials)
# GOOGLE_CLIENT_SECRET is stored here for future use but not currently
# read by any code - our login flow only needs the Client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# prod only
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
